APP_NAME=TUTORKU
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Gunakan sqlite secara default (paling mudah untuk development).
# Ganti ke mysql jika dibutuhkan untuk production.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=TUTORKU
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Frontend (React/Vite) URL - dipakai untuk CORS & Sanctum stateful domain
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database
# PENTING: Notifikasi booking/pembayaran/chat baru dikirim via queue (database driver).
# Jalankan `php artisan queue:work` di proses terpisah agar notifikasi tersebut benar-benar
# terkirim (OTP login TIDAK terpengaruh, OTP selalu dikirim langsung/synchronous).

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (https://resend.com) - email provider gratis (100 email/hari) untuk kirim OTP Google.
# Daftar gratis, verifikasi domain di Resend, lalu isi RESEND_API_KEY di bawah.
# Jika belum memverifikasi domain, Anda bisa coba `onboarding@resend.dev` sebagai alamat pengirim.
# Untuk development lokal tanpa pengiriman ke inbox nyata, gunakan MAIL_MAILER=smtp + Mailpit.
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ───────── AUTHENTICATION: Google OAuth ─────────
# 1. Buka https://console.cloud.google.com/apis/credentials
# 2. Buat OAuth Client ID tipe "Web application"
# 3. Authorized redirect URI: http://localhost:8000/api/auth/google/callback
#    (sesuaikan domain saat production, contoh: https://api.TUTORKU.id/api/auth/google/callback)
# 4. Salin Client ID & Client Secret ke bawah ini.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Login Google untuk Tutor (tanpa OTP, beda flow dengan siswa di atas).
# Tambahkan juga URI ini ke "Authorized redirect URIs" di Google Cloud Console.
GOOGLE_TUTOR_REDIRECT_URI=http://localhost:8000/api/auth/tutor/google/callback

# ───────── AUTHENTICATION: Google reCAPTCHA (Pengajuan Tutor) ─────────
# Daftar gratis di https://www.google.com/recaptcha/admin (pilih reCAPTCHA v2 "I'm not a robot")
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
VITE_RECAPTCHA_SITE_KEY="${RECAPTCHA_SITE_KEY}"

# ───────── Broadcasting (Realtime Chat, Notifikasi, Live Class, Whiteboard) ─────────
# Laravel Reverb: WebSocket server resmi Laravel, open-source & gratis (self-hosted).
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=TUTORKU
REVERB_APP_KEY=TUTORKU-key
REVERB_APP_SECRET=TUTORKU-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ───────── Payment Gateway ─────────
PAYMENT_GATEWAY=midtrans
# Midtrans (https://dashboard.midtrans.com) - mode sandbox secara default
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Xendit (https://dashboard.xendit.co) - alternatif gateway
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=

# Platform fee (Rp) yang ditambahkan ke setiap booking
PLATFORM_SERVICE_FEE=2500

# ───────── AUTHENTICATION: OTP Nomor Telepon via WhatsApp ─────────
# Pakai Fonnte (https://fonnte.com) - ada free trial device, paling realistis
# untuk OTP nomor telepon di Indonesia dibanding SMS gateway global yang berbayar penuh.
# Tanpa token diisi, OTP otomatis di-log ke storage/logs/laravel.log (mode dev, supaya tetap bisa ditest).
WHATSAPP_PROVIDER=fonnte
WHATSAPP_API_TOKEN=

# ───────── Live Class (WebRTC) ─────────
# WebRTC peer-to-peer murni gratis, signaling dilakukan lewat Reverb (channel privat per room).
# STUN server gratis dari Google dipakai di sisi frontend: stun:stun.l.google.com:19302
# Kalau butuh TURN server gratis untuk NAT traversal yang lebih reliable, bisa pakai Open Relay (Metered.ca free tier).
WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302

VITE_APP_NAME="${APP_NAME}"
