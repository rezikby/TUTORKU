APP_NAME=TUTORKU
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=tutorku
# DB_USERNAME=root
# DB_PASSWORD=

# Queue & Cache
QUEUE_CONNECTION=database
CACHE_STORE=database
DB_QUEUE_CONNECTION=${DB_CONNECTION}
DB_QUEUE_TABLE=jobs
DB_QUEUE_RETRY_AFTER=90
DB_QUEUE_AFTER_COMMIT=false
DB_QUEUE_BATCH_TABLE=job_batches
DB_QUEUE_FAILED_TABLE=failed_jobs

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

FILESYSTEM_DISK=public
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# OAuth / Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_TUTOR_REDIRECT_URI=http://localhost:8000/api/auth/tutor/google/callback

# reCAPTCHA
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
VITE_RECAPTCHA_SITE_KEY="${RECAPTCHA_SITE_KEY}"

# Reverb / Broadcasting
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=TUTORKU
REVERB_APP_KEY=TUTORKU-key
REVERB_APP_SECRET=TUTORKU-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Payment Gateway
PAYMENT_GATEWAY=midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=
PLATFORM_SERVICE_FEE=2500

# WhatsApp OTP
WHATSAPP_PROVIDER=fonnte
WHATSAPP_API_TOKEN=

# Live Class / WebRTC
WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302

VITE_APP_NAME="${APP_NAME}"
